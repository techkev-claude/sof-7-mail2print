# ── Allgemein ────────────────────────────────────────────────
PORT=8084
TZ=Europe/Berlin
LOG_LEVEL=INFO
DATA_PATH=/home/user/mail2print/data

# ── IMAP ─────────────────────────────────────────────────────
IMAP_HOST=imap.netcup.de
IMAP_PORT=993
IMAP_USER=printer@example.com
IMAP_PASSWORD=changeme
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
IMAP_TRASH_FOLDER=Trash
POLL_INTERVAL_SECONDS=60

# Kommagetrennte Liste erlaubter Absender (leer = alle erlaubt)
ALLOWED_SENDERS=

# ── Drucker ──────────────────────────────────────────────────
PRINTER_NAME=mail2print
PRINTER_HOST=192.168.0.141
PRINTER_PORT=9100
# Zusätzliche lp-Optionen, z.B.: sides=two-sided-long-edge media=A4
PRINT_OPTIONS=

# Erlaubte Anhang-MIME-Types (kommagetrennt)
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/tiff

# ── SMTP (für Fehler- und Format-Benachrichtigungen) ─────────
SMTP_HOST=mail.netcup.de
SMTP_PORT=587
SMTP_USER=printer@example.com
SMTP_PASSWORD=changeme
# true = STARTTLS (Port 587), false = Implicit SSL (Port 465)
SMTP_USE_STARTTLS=true
SMTP_FROM=printer@example.com

# Admin-E-Mail für Fehlerbenachrichtigungen
ADMIN_EMAIL=admin@example.com

# ── Webhook ──────────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_METHOD=POST
WEBHOOK_TIMEOUT=10
# HMAC-Secret für X-Mail2Print-Signature Header (leer = kein Header)
WEBHOOK_SECRET=
